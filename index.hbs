{{!< default}}

<section class="hero hero-icrs floating-block bordered-block">
    <div class="hero-inner">
        <div class="hero-left">
            {{#if @site.logo}}
                <div class="hero-logo-mask" style="-webkit-mask-image: url({{@site.logo}}); mask-image: url({{@site.logo}});"></div>
            {{else}}
                <h1 class="hero-massive-title hatching-text">ICRS</h1>
            {{/if}}
        </div>
        <div class="hero-right">
            <p class="hero-description">
                <strong>ICRS</strong> is Imperial’s home for robotics, making, and creative engineering. We provide a dedicated lab space (EEE 505) where students can design, prototype, and experiment with their own projects.
                <br><br>
                <a href="/about/">&lt;more&gt;</a>
            </p>
            <div class="hero-tags-links">
                {{#if @custom.hero_tag_1_text}}
                    <a href="{{@custom.hero_tag_1_url}}" class="hero-tag" {{#if @custom.hero_tag_1_color}}style="color: {{@custom.hero_tag_1_color}}"{{/if}}>{{@custom.hero_tag_1_text}}</a>
                {{/if}}
                {{#if @custom.hero_tag_2_text}}
                    <a href="{{@custom.hero_tag_2_url}}" class="hero-tag" {{#if @custom.hero_tag_2_color}}style="color: {{@custom.hero_tag_2_color}}"{{/if}}>{{@custom.hero_tag_2_text}}</a>
                {{/if}}
                {{#if @custom.hero_tag_3_text}}
                    <a href="{{@custom.hero_tag_3_url}}" class="hero-tag" {{#if @custom.hero_tag_3_color}}style="color: {{@custom.hero_tag_3_color}}"{{/if}}>{{@custom.hero_tag_3_text}}</a>
                {{/if}}
            </div>
        </div>
    </div>
</section>

<div class="spacer-block floating-block bordered-block"></div>

<section class="post-feed-container floating-block">
    <div class="section-label">[POSTS]</div>
    <div class="post-feed">
        {{#get "posts" filter="tag:hash-icrs-post" limit="12" include="tags,authors" as |icrs_posts|}}
            {{#foreach icrs_posts}}
                {{> post-card}}
            {{/foreach}}
        {{/get}}
    </div>
</section>

<section class="gallery-marquee-container floating-block">
    <div class="section-label">[GALLERY]</div>
    <div class="gallery-marquee-wrapper">
        <div class="gallery-marquee">
            <div class="marquee-item placeholder-block"></div>
            <div class="marquee-item placeholder-block"></div>
            <div class="marquee-item placeholder-block"></div>
            <div class="marquee-item placeholder-block"></div>
            <div class="marquee-item placeholder-block"></div>
            <!-- Duplicated for seamless looping -->
            <div class="marquee-item placeholder-block"></div>
            <div class="marquee-item placeholder-block"></div>
            <div class="marquee-item placeholder-block"></div>
            <div class="marquee-item placeholder-block"></div>
            <div class="marquee-item placeholder-block"></div>
        </div>
    </div>
</section>

{{#get "posts" filter="tag:hash-icrs-sponsor" limit="all" include="tags" as |sponsors|}}
    {{#if sponsors}}
    <div class="spacer-block floating-block"></div>
    <section class="sponsors-container floating-block bordered-block">
        <div class="section-label">[SPONSORS]</div>
        <div class="sponsors-grid">
            {{#foreach sponsors}}
                {{#if canonical_url}}
                    <a href="{{canonical_url}}"
                       class="sponsor-item"
                       title="{{title}}"
                       target="_blank"
                       rel="noopener sponsored">
                        {{#if feature_image}}
                            <img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy">
                        {{else}}
                            <span class="sponsor-name">{{title}}</span>
                        {{/if}}
                    </a>
                {{else}}
                    <div class="sponsor-item" title="{{title}}">
                        {{#if feature_image}}
                            <img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy">
                        {{else}}
                            <span class="sponsor-name">{{title}}</span>
                        {{/if}}
                    </div>
                {{/if}}
            {{/foreach}}
        </div>
    </section>
    {{/if}}
{{/get}}

{{> pagination}}
