{{!< default}}

{{#post}}
<article class="post-full">
    <header class="post-header">
        <div class="post-header-meta">
            {{#if primary_tag}}
            <a class="post-tag" href="{{primary_tag.url}}">{{primary_tag.name}}</a>
            {{/if}}
            <time class="post-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD.MM.YYYY"}}</time>
        </div>
        <h1 class="post-title">{{title}}</h1>
        {{#if custom_excerpt}}
        <p class="post-excerpt">{{custom_excerpt}}</p>
        {{/if}}
        <div class="post-byline">
            {{#foreach authors}}
            <span class="post-author">
                {{#if profile_image}}
                <img class="post-author-avatar" src="{{img_url profile_image size="xs"}}" alt="{{name}}">
                {{/if}}
                <a href="{{url}}">{{name}}</a>
            </span>
            {{/foreach}}
            <span class="post-reading-time">{{reading_time}}</span>
        </div>
    </header>

    {{#if feature_image}}
    <figure class="post-feature-image">
        <img
            srcset="{{img_url feature_image size="s"}} 300w,
                    {{img_url feature_image size="m"}} 600w,
                    {{img_url feature_image size="l"}} 1000w,
                    {{img_url feature_image size="xl"}} 2000w"
            sizes="(min-width: 1000px) 1000px, 90vw"
            src="{{img_url feature_image size="xl"}}"
            alt="{{title}}"
        >
        {{#if feature_image_caption}}
        <figcaption>{{feature_image_caption}}</figcaption>
        {{/if}}
    </figure>
    {{/if}}

    <div class="post-content gh-content">
        {{content}}
    </div>
</article>

{{#if tags}}
<div class="post-tags">
    <span class="post-tags-label">[TAGS]</span>
    {{#foreach tags}}
    <a class="post-tags-item" href="{{url}}">{{name}}</a>
    {{/foreach}}
</div>
{{/if}}

<div class="read-next">
    <div class="section-label">[READ MORE]</div>
    <div class="post-feed">
        {{#next_post}}
            {{> post-card}}
        {{/next_post}}
        {{#prev_post}}
            {{> post-card}}
        {{/prev_post}}
    </div>
</div>
{{/post}}
