<article class="post-card {{#if featured}}post-card--featured{{/if}}">
    <a class="post-card-link" href="{{url}}">
        {{#if feature_image}}
        <div class="post-card-image">
            <img
                srcset="{{img_url feature_image size="s"}} 300w,
                        {{img_url feature_image size="m"}} 600w,
                        {{img_url feature_image size="l"}} 1000w"
                sizes="(max-width: 600px) 300px, (max-width: 1000px) 600px, 1000px"
                src="{{img_url feature_image size="m"}}"
                alt="{{title}}"
                loading="lazy"
            >
        </div>
        {{else}}
        <div class="post-card-image post-card-image--empty">
            <div class="hatching-fill"></div>
        </div>
        {{/if}}
        <div class="post-card-content">
            <div class="post-card-meta">
                {{#if primary_tag}}
                <span class="post-card-tag" {{#if primary_tag.accent_color}}style="color: {{primary_tag.accent_color}};"{{/if}}>[{{primary_tag.name}}]</span>
                {{/if}}
                <time class="post-card-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD.MM.YY"}}</time>
            </div>
            <h2 class="post-card-title">{{title}}</h2>
            {{#if excerpt}}
            <p class="post-card-excerpt">{{excerpt words="20"}}</p>
            {{/if}}
        </div>
    </a>
</article>
